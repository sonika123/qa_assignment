                      "});",
                      "",
                      "pm.test(\"Status updated to COMPLETED\", () => {",
                      "  const json = pm.response.json();",
                      "  // suppose api returns staus : COMPLETED in json response",
                      "  pm.expect(json.status).to.eql(\"COMPLETED\"); ",
                      "});",
                      ""
