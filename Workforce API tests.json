    {
      "name": "Positive scenarios",
      "item": [
        {
          "name": "Employees",
          "item": [
            {
              "name": "Create Employees",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 201\", function () {",
                      "    pm.response.to.have.status(201);",
                      "});",
                      "",
                      "pm.test(\"Response has required fields\", () => {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json).to.have.property(\"emp_id\");",
                      "  pm.expect(json).to.have.property(\"emp_name\");",
                      "  pm.expect(json).to.have.property(\"emp_email\");",
                      "  pm.expect(json).to.have.property(\"emp_department\");",
                      "  pm.expect(json).to.have.property(\"emp_supervisor\");",
                      "});",
                      "",
                      "pm.test(\"Employee data is correct\", () => {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.emp_email).to.eql(\"ram.dahal@example.com\");",
                      "  pm.expect(json.emp_name).to.eql(\"Ram Dahal\");",
                      "});",
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"emp_id\": \"EMP001\",\n    \"emp_name\": \"Ram Dahal\",\n    \"emp_email\": \"ram.dahal@example.com\",\n    \"emp_department\": \"Engineering\",\n    \"emp_supervisor\": \"Shyam Jha\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{base_url}}api/employees",
                  "host": [
                    "{{base_url}}api"
                  ],
                  "path": [
                    "employees"
                  ]
                },
                "description": "Expected result :  \n201 Created"
              },
              "response": []
            },
            {
              "name": "Retrieve Employees",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status is 200 OK\", () => {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test(\"Response contains employee ID\", () => {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.id).to.eql(pm.collectionVariables.get(\"emp_id\"));",
                      "});",
                      "",
                      "pm.test(\"Required fields present\", () => {",
                      "  const json = pm.response.json();",
                      "  [\"emp_id\", \"emp_name\", \"emp_email\", \"emp_department\", \"emp_supervisor\"].forEach(field => {",
                      "    pm.expect(json).to.have.property(field);",
                      "  });",
                      "});"
                    ],
