        {
          "name": "Training",
          "item": [
            {
              "name": "Assign Training",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status is 201 Created\", () => {",
                      "  pm.response.to.have.status(201);",
                      "});",
                      "",
                      "pm.test(\"Assigned training has required fields\", () => {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json).to.have.property(\"training_id\");",
                      "  pm.expect(json).to.have.property(\"emp_id\");",
                      "  pm.expect(json).to.have.property(\"due_date\");",
                      "});",
                      "",
                      "pm.collectionVariables.set(\"training_id\", pm.response.json().training_id);"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"emp_id\":\"EMP001\",\n    \"training_id\": \"TR001\",\n    \"due_date\" : \"2026-08-01\"\n}",
